{
  "name": "relentify-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:generate": "pnpm --filter @relentify/database db:generate",
    "db:migrate": "pnpm --filter @relentify/database db:migrate",
    "db:studio": "pnpm --filter @relentify/database db:studio"
  },
  "devDependencies": {
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "turbo": "^2.8.17",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "overrides": {
      "fast-xml-parser": ">=5.5.7",
      "@tootallnate/once": ">=3.0.1",
      "yaml": ">=2.8.3",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "brace-expansion@<5.0.5": ">=5.0.5"
    }
  }
}
