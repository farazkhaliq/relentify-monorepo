/**
 * # Firestore Security Rules for Relentify CRM
 *
 * ## Core Philosophy
 * This ruleset enforces a strict multi-tenant security model. All data for a
 * specific agency is isolated within its own document tree, ensuring that users
 * from one organization cannot access data from another. Access is primarily
 * governed by roles defined within the database, distinguishing between global
 * System Administrators, agency-level Staff/Admins, and external Portal Users
 * (Tenants/Landlords). The default security posture is to deny access unless
 * explicitly granted.
 *
 * ## Data Structure
 * - `/organizations/{organizationId}`: The root for all data belonging to a
 *   single agency. All operational data (contacts, properties, tasks, etc.)
 *   exists in subcollections under this path.
 * - `/systemAdmins/{userId}`: A top-level collection that grants global
 *   administrative privileges. A user's existence in this collection elevates
 *   their permissions across the entire database.
 * - `/portalUserProfiles/{portalUserId}`: A mapping collection that links a
 *   Firebase Authentication user (e.g., a tenant or landlord) to their
 *   corresponding Contact record within a specific organization. This allows
 *   external users to securely access only the data they are explicitly linked to.
 *
 * ## Key Security Decisions
 * - **Strict Multi-Tenancy**: All rules for data within an organization begin
 *   by verifying the user belongs to that organization. Cross-organization
 *   queries are impossible.
 * - **Role-Based Access Control (RBAC)**: User permissions are determined by
 *   their role (`Admin` or `Staff`) stored in their userProfile document within
 *   their organization, or by their existence in the `/systemAdmins` collection.
 * - **Denormalization for Authorization**: To ensure fast and secure rule
 *   evaluation, every document within an organization's data tree contains a
 *   denormalized `organizationId` field. This avoids slow and costly `get()` calls
 *   to parent documents and is the cornerstone of the security model.
 * - **Append-Only Audit Logs**: The `auditLogs` collection is immutable. Documents
 *   can be created but never updated or deleted, ensuring a permanent record
 *   of all actions.
 * - **Restricted User Enumeration**: Listing users is generally disallowed to
 *   protect privacy. Only System Admins or Agency Admins can list staff profiles.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------

    /**
     * Checks if a user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the authenticated user's UID matches the provided userId.
     * Used for rules where a user can access their own data.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if the current user is a global System Administrator by verifying
     * the existence of their user ID in the `/systemAdmins` collection.
     */
    function isSystemAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/systemAdmins/$(request.auth.uid));
    }

    /**
     * Retrieves the staff profile for the currently authenticated user within a
     * given organization.
     */
    function getStaffProfile(organizationId) {
      return get(/databases/$(database)/documents/organizations/$(organizationId)/userProfiles/$(request.auth.uid)).data;
    }

    /**
     * Checks if the authenticated user is an active staff member of the specified
     * organization.
     * RELAXED FOR DEVELOPMENT: Allows any signed-in user (including anonymous).
     */
    function isStaffOfOrg(organizationId) {
      return isSignedIn();
      /* Original strict rule:
      return isSignedIn()
        && exists(/databases/$(database)/documents/organizations/$(organizationId)/userProfiles/$(request.auth.uid))
        && getStaffProfile(organizationId).status == 'Active';
      */
    }

    /**
     * Checks if the authenticated user is an Agency Admin for the specified
     * organization by checking their role.
     */
    function isAgencyAdmin(organizationId) {
      return isStaffOfOrg(organizationId) && getStaffProfile(organizationId).role == 'Admin';
    }

    /**
     * Retrieves the profile for an external portal user (e.g., Tenant, Landlord),
     * which links their auth UID to a contact ID and organization ID.
     */
    function getPortalUserProfile() {
      return get(/databases/$(database)/documents/portalUserProfiles/$(request.auth.uid)).data;
    }

    /**
     * Checks if the authenticated user is a registered portal user associated
     * with the specified organization.
     */
    function isPortalUserOfOrg(organizationId) {
      return isSignedIn() && exists(/databases/$(database)/documents/portalUserProfiles/$(request.auth.uid)) && getPortalUserProfile().organizationId == organizationId;
    }

    /**
     * Validates that the organizationId in a document being created matches the
     * organizationId from the path. This enforces multi-tenant data integrity.
     */
    function isConsistentOrgOnCreate(organizationId) {
      return request.resource.data.organizationId == organizationId;
    }

    /**
     * Validates that the organizationId of a document cannot be changed during an update.
     * This prevents a document from being moved between organizations.
     */
    function isImmutableOrgOnUpdate() {
      return request.resource.data.organizationId == resource.data.organizationId;
    }

    // -------------------------------------------------------------------------
    // Top-Level Collection Rules
    // -------------------------------------------------------------------------

    /**
     * @description Controls access to the collection of global system administrators.
     * @path /systemAdmins/{userId}
     * @allow (get) A System Admin can read another admin's record.
     * @deny (create) A non-System Admin cannot add a new admin.
     * @principle Restricts high-privilege role management to existing administrators.
     */
    match /systemAdmins/{userId} {
      allow get: if isSystemAdmin();
      allow list: if isSystemAdmin();
      allow create: if isSystemAdmin();
      allow update: if isSystemAdmin() && resource != null;
      allow delete: if isSystemAdmin() && resource != null;
    }

    /**
     * @description Manages profiles for external portal users (Tenants, Landlords).
     * @path /portalUserProfiles/{portalUserId}
     * @allow (create) A new user can create their own portal profile.
     * @deny (get) A user cannot read another user's portal profile.
     * @principle Enforces self-service for portal user registration while maintaining privacy.
     */
    match /portalUserProfiles/{portalUserId} {
      allow get: if isOwner(portalUserId) || isSystemAdmin();
      allow list: if isSystemAdmin(); // Prevent user enumeration
      allow create: if isOwner(portalUserId);
      allow update: if (isOwner(portalUserId) || isSystemAdmin()) && resource != null;
      allow delete: if (isOwner(portalUserId) || isSystemAdmin()) && resource != null;
    }

    /**
     * @description Manages the mapping between a staff user's UID and their organization ID.
     * @path /userOrganizationMap/{userId}
     * @allow (get) A user can read their own organization mapping.
     * @allow (create) A new user can create their own mapping document during signup.
     * @deny (update) The organization mapping is immutable once created.
     * @principle Provides a secure and efficient way to determine a user's organization on login.
     */
    match /userOrganizationMap/{userId} {
      allow get: if isOwner(userId) || isSystemAdmin();
      allow create: if isOwner(userId);
      allow update: if false; // Should not be updatable from client
      allow delete: if isSystemAdmin(); // Only system admin can unmap a user
    }

    /**
     * @description Publicly readable property listings for external data feeds.
     * @path /propertyListings/{propertyId}
     * @allow (get, list) Anyone can read property listings for data feeds.
     * @allow (create, update) Only authenticated staff members of the corresponding organization can publish or update a listing.
     * @principle Separates public listing data from private property data, enabling secure external integrations.
     */
    match /propertyListings/{propertyId} {
      allow get, list: if true;
      allow create, update: if request.auth != null
                        && request.resource.data.organizationId != null
                        && isStaffOfOrg(request.resource.data.organizationId);
      allow delete: if request.auth != null
                && resource.data.organizationId != null
                && isAgencyAdmin(resource.data.organizationId);
    }

    /**
     * @description Defines the root document for each agency/organization.
     * @path /organizations/{organizationId}
     * @allow (get) An authenticated staff member can read their organization's details.
     * @deny (create) A non-System Admin cannot create a new organization.
     * @principle Segregates all data by organization and restricts org management to System Admins.
     */
    match /organizations/{organizationId} {
      allow get: if isStaffOfOrg(organizationId) || isSystemAdmin();
      allow list: if isSystemAdmin(); // Prevent listing all organizations
      allow create: if isSystemAdmin();
      allow update: if (isAgencyAdmin(organizationId) || isSystemAdmin()) && resource != null;
      allow delete: if isSystemAdmin() && resource != null;

      // -----------------------------------------------------------------------
      // Organization Sub-Collection Rules
      // -----------------------------------------------------------------------

      /**
       * @description Manages staff member profiles within an organization.
       * @path /organizations/{organizationId}/userProfiles/{userProfileId}
       * @allow (create) A new user can create their own profile during sign-up.
       * @allow (get) A staff member can read their own profile.
       * @allow (list) An Agency Admin can list all users in their organization.
       * @deny (update) A regular staff member cannot change their own role to 'Admin'.
       * @principle Allows self-creation, restricts listing to Admins, and prevents self-promotion.
       */
      match /userProfiles/{userProfileId} {
        allow get: if isOwner(userProfileId) || isStaffOfOrg(organizationId) || isSystemAdmin();
        allow list: if isAgencyAdmin(organizationId) || isSystemAdmin();
        allow create: if (isOwner(userProfileId) && isConsistentOrgOnCreate(organizationId)) || (isAgencyAdmin(organizationId) || isSystemAdmin());
        allow update: if ( (isAgencyAdmin(organizationId) || isSystemAdmin()) || (isOwner(userProfileId) && request.resource.data.role == resource.data.role) ) && resource != null;
        allow delete: if (isAgencyAdmin(organizationId) || isSystemAdmin()) && resource != null;
      }

      /**
       * @description Secures contacts (landlords, tenants, leads) for an organization.
       * @path /organizations/{organizationId}/contacts/{contactId}
       * @allow (get, list, create) A staff member of the org can manage contacts.
       * @deny (get) A staff member from another org cannot read contacts.
       * @principle Enforces that all contact data is strictly confined to the parent organization.
       */
      match /contacts/{contactId} {
        allow get, list: if isStaffOfOrg(organizationId) || isPortalUserOfOrg(organizationId) || isSystemAdmin();
        allow create: if (isStaffOfOrg(organizationId) || isSystemAdmin()) && isConsistentOrgOnCreate(organizationId);
        allow update: if (isStaffOfOrg(organizationId) || isSystemAdmin()) && resource != null && isImmutableOrgOnUpdate();
        allow delete: if (isAgencyAdmin(organizationId) || isSystemAdmin()) && resource != null;
      }

      /**
       * @description Secures property data for an organization.
       * @path /organizations/{organizationId}/properties/{propertyId}
       * @allow (get, list) A staff or portal user of the org can view properties.
       * @deny (update) A portal user cannot modify property details.
       * @principle Enforces that all property data is strictly confined to the parent organization for viewing, but writable only by staff.
       */
      match /properties/{propertyId} {
        allow get, list: if isStaffOfOrg(organizationId) || isPortalUserOfOrg(organizationId) || isSystemAdmin();
        allow create: if (isStaffOfOrg(organizationId) || isSystemAdmin()) && isConsistentOrgOnCreate(organizationId);
        allow update: if (isStaffOfOrg(organizationId) || isSystemAdmin()) && resource != null && isImmutableOrgOnUpdate();
        allow delete: if (isAgencyAdmin(organizationId) || isSystemAdmin()) && resource != null;
      }

      /**
       * @description Secures tenancy agreement data for an organization.
       * @path /organizations/{organizationId}/tenancies/{tenancyId}
       * @allow (get) A staff member or an involved portal user can read the tenancy.
       * @deny (get) A staff member from another org cannot read tenancy data.
       * @principle Enforces that all tenancy data is strictly confined to the parent organization and involved parties.
       */
      match /tenancies/{tenancyId} {
        allow get, list: if isStaffOfOrg(organizationId) || (isPortalUserOfOrg(organizationId) && (getPortalUserProfile().contactId in resource.data.tenantIds || getPortalUserProfile().contactId in resource.data.landlordIds)) || isSystemAdmin();
        allow create: if (isStaffOfOrg(organizationId) || isSystemAdmin()) && isConsistentOrgOnCreate(organizationId) && request.resource.data.createdByUserId == request.auth.uid;
        allow update: if (isStaffOfOrg(organizationId) || isSystemAdmin()) && resource != null && isImmutableOrgOnUpdate() && request.resource.data.createdByUserId == resource.data.createdByUserId;
        allow delete: if (isAgencyAdmin(organizationId) || isSystemAdmin()) && resource != null;
      }

      /**
       * @description Secures maintenance requests for an organization.
       * @path /organizations/{organizationId}/maintenanceRequests/{maintenanceRequestId}
       * @allow (create) A portal user (e.g., tenant) can create a new maintenance request.
       * @deny (update) A portal user cannot update a maintenance request once submitted.
       * @principle Allows portal users to submit requests but restricts management to internal staff.
       */
      match /maintenanceRequests/{maintenanceRequestId} {
        allow get, list: if isStaffOfOrg(organizationId) || isSystemAdmin() || (isPortalUserOfOrg(organizationId) && (getPortalUserProfile().contactId == resource.data.reporterContactId || (resource.data.propertyId != null && get(/databases/$(database)/documents/organizations/$(organizationId)/properties/$(resource.data.propertyId)).data.landlordIds.hasAny([getPortalUserProfile().contactId]))));
        allow create: if (isStaffOfOrg(organizationId) || isPortalUserOfOrg(organizationId) || isSystemAdmin()) && isConsistentOrgOnCreate(organizationId);
        allow update: if (isStaffOfOrg(organizationId) || isSystemAdmin()) && resource != null && isImmutableOrgOnUpdate();
        allow delete: if (isAgencyAdmin(organizationId) || isSystemAdmin()) && resource != null;
      }

      /**
       * @description Secures document metadata for an organization.
       * @path /organizations/{organizationId}/documents/{documentId}
       * @allow (get, list, create) A staff member of the org can manage documents.
       * @deny (delete) A portal user cannot delete documents.
       * @principle Enforces that all document metadata is strictly confined to the parent organization.
       */
      match /documents/{documentId} {
        allow get, list: if isStaffOfOrg(organizationId) || isSystemAdmin() || (isPortalUserOfOrg(organizationId) && resource.data.contactIds.hasAny([getPortalUserProfile().contactId]));
        allow create: if (isStaffOfOrg(organizationId) || isSystemAdmin()) && isConsistentOrgOnCreate(organizationId);
        allow update: if (isStaffOfOrg(organizationId) || isSystemAdmin()) && resource != null && isImmutableOrgOnUpdate();
        allow delete: if (isAgencyAdmin(organizationId) || isSystemAdmin()) && resource != null;
      }

      /**
       * @description Secures financial transactions for an organization.
       * @path /organizations/{organizationId}/transactions/{transactionId}
       * @allow (get, list, create) A staff member of the org can manage transactions.
       * @deny (create) A portal user cannot create financial transactions.
       * @principle Restricts financial data management to authorized internal staff.
       */
      match /transactions/{transactionId} {
        allow get, list: if isStaffOfOrg(organizationId) || isSystemAdmin() || (isPortalUserOfOrg(organizationId) && (getPortalUserProfile().contactId == resource.data.payerContactId || getPortalUserProfile().contactId == resource.data.payeeContactId || (resource.data.relatedPropertyId != null && get(/databases/$(database)/documents/organizations/$(organizationId)/properties/$(resource.data.relatedPropertyId)).data.landlordIds.hasAny([getPortalUserProfile().contactId]))));
        allow create: if (isStaffOfOrg(organizationId) || isSystemAdmin()) && isConsistentOrgOnCreate(organizationId);
        allow update: if (isStaffOfOrg(organizationId) || isSystemAdmin()) && resource != null && isImmutableOrgOnUpdate();
        allow delete: if (isAgencyAdmin(organizationId) || isSystemAdmin()) && resource != null;
      }
      
      /**
       * @description Secures linked bank accounts for an organization.
       * @path /organizations/{organizationId}/bankAccounts/{bankAccountId}
       * @allow (get, list, create, update, delete) Only an Agency Admin can manage linked bank accounts.
       * @principle Restricts sensitive financial integration details to admin-level users.
       */
      match /bankAccounts/{bankAccountId} {
        allow get, list: if isAgencyAdmin(organizationId) || isSystemAdmin();
        allow create: if (isAgencyAdmin(organizationId) || isSystemAdmin()) && isConsistentOrgOnCreate(organizationId);
        allow update: if (isAgencyAdmin(organizationId) || isSystemAdmin()) && resource != null && isImmutableOrgOnUpdate();
        allow delete: if (isAgencyAdmin(organizationId) || isSystemAdmin()) && resource != null;
      }

      /**
       * @description Secures workflow automation rules for an organization.
       * @path /organizations/{organizationId}/workflowRules/{workflowRuleId}
       * @allow (create) An Agency Admin can create a new workflow rule.
       * @deny (create, update, delete) A regular staff member cannot manage workflow rules.
       * @principle Elevates workflow configuration to Admin-level users only.
       */
      match /workflowRules/{workflowRuleId} {
        allow get, list: if isAgencyAdmin(organizationId) || isSystemAdmin();
        allow create: if (isAgencyAdmin(organizationId) || isSystemAdmin()) && isConsistentOrgOnCreate(organizationId);
        allow update: if (isAgencyAdmin(organizationId) || isSystemAdmin()) && resource != null && isImmutableOrgOnUpdate();
        allow delete: if (isAgencyAdmin(organizationId) || isSystemAdmin()) && resource != null;
      }

      /**
       * @description Secures the audit log, making it append-only.
       * @path /organizations/{organizationId}/auditLogs/{auditLogId}
       * @allow (create) An internal staff member's actions can create an audit log entry.
       * @deny (update, delete) No user, including admins, can modify or delete an audit log entry.
       * @principle Ensures the integrity and immutability of the audit trail.
       */
      match /auditLogs/{auditLogId} {
        allow get, list: if isStaffOfOrg(organizationId) || isSystemAdmin();
        allow create: if (isStaffOfOrg(organizationId) || isSystemAdmin()) && isConsistentOrgOnCreate(organizationId);
        allow update: if false;
        allow delete: if false;
      }

      /**
       * @description Secures communications (emails, SMS) for an organization.
       * @path /organizations/{organizationId}/communications/{communicationId}
       * @allow (get, list, create) A staff member can view and log communications.
       * @deny (get) A user from another organization cannot read communications.
       * @principle Confines all communication records to the relevant organization.
       */
      match /communications/{communicationId} {
        allow get, list: if isStaffOfOrg(organizationId) || isSystemAdmin();
        allow create: if (isStaffOfOrg(organizationId) || isSystemAdmin()) && isConsistentOrgOnCreate(organizationId);
        allow update: if (isStaffOfOrg(organizationId) || isSystemAdmin()) && resource != null && isImmutableOrgOnUpdate();
        allow delete: if (isStaffOfOrg(organizationId) || isSystemAdmin()) && resource != null;
      }

      /**
       * @description Secures tasks and to-do items for an organization.
       * @path /organizations/{organizationId}/tasks/{taskId}
       * @allow (get, list, create) A staff member can manage tasks within their organization.
       * @deny (get) A portal user cannot see internal staff tasks.
       * @principle Enforces that all task data is strictly confined to the parent organization.
       */
      match /tasks/{taskId} {
        allow get, list: if isStaffOfOrg(organizationId) || isSystemAdmin();
        allow create: if (isStaffOfOrg(organizationId) || isSystemAdmin()) && isConsistentOrgOnCreate(organizationId) && request.resource.data.createdByUserId == request.auth.uid;
        allow update: if (isStaffOfOrg(organizationId) || isSystemAdmin()) && resource != null && isImmutableOrgOnUpdate() && request.resource.data.createdByUserId == resource.data.createdByUserId;
        allow delete: if (isAgencyAdmin(organizationId) || isSystemAdmin()) && resource != null;
      }

      /**
       * @description Secures notifications for users within an organization.
       * @path /organizations/{organizationId}/notifications/{notificationId}
       * @allow (get, list, update) A user can read and update (e.g., mark as read) their own notifications.
       * @allow (create) An internal staff member can create a notification for another user.
       * @allow (delete) A user can delete their own notifications.
       * @principle Confines notification access to the intended recipient.
       */
      match /notifications/{notificationId} {
        allow get, list, update: if isStaffOfOrg(organizationId); // RELAXED FOR DEV: resource.data.userId == request.auth.uid removed
        allow create: if isStaffOfOrg(organizationId) && isConsistentOrgOnCreate(organizationId);
        allow delete: if isStaffOfOrg(organizationId); // RELAXED FOR DEV: resource.data.userId == request.auth.uid removed
      }
    }
  }
}
