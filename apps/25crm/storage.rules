rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Path for organization-specific files
    match /organizations/{organizationId}/{allPaths=**} {
      // Allow writes only by authenticated staff members of that organization
      allow write: if request.auth != null && exists(/databases/$(database)/documents/organizations/$(organizationId)/userProfiles/$(request.auth.uid));

      // Allow reads by authenticated staff members of that organization
      allow read: if request.auth != null && exists(/databases/$(database)/documents/organizations/$(organizationId)/userProfiles/$(request.auth.uid));
    }
  }
}
